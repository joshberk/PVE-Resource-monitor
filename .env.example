SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
PVE_NODE_NAME=node1
FAIL_ON_CRITICAL_ALERTS=false

# Health alert thresholds for Dell PowerEdge R830 (optional — these are the defaults)
INLET_WARN_C=30
INLET_CRIT_C=40
EXHAUST_WARN_C=55
EXHAUST_CRIT_C=70
CPU_WARN_C=75
CPU_CRIT_C=85
FAN_MIN_RPM=1000
VBAT_WARN_V=2.7
